{
    "name": "ecommerce-legacy-frontend",
    "version": "1.0.0",
    "description": "Legacy E-commerce Frontend Application",
    "private": true,
    "scripts": {
        "start": "npm run build && node bin/www",
        "prestart": "npm install",
        "predev": "npm install",
        "pretest": "npm install",
        "dev": "NODE_ENV=development npm run watch & nodemon bin/www",
        "build": "NODE_ENV=production node ./api/esbuild.js",
        "watch": "NODE_ENV=development node ./api/esbuild.js --watch",
        "test": "jest --runInBand --colors"
    },
    "dependencies": {
        "@babel/core": "^7.23.0",
        "@babel/preset-env": "^7.22.20",
        "@babel/preset-react": "^7.22.15",
        "@babel/preset-typescript": "^7.23.0",
        "@babel/register": "^7.22.15",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-session": "^1.18.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.1.4",
        "@testing-library/react": "^14.0.0",
        "@types/express": "^4.17.20",
        "@types/express-session": "^1.17.10",
        "@types/jest": "^30.0.0",
        "@types/node": "^20.0.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "babel-jest": "^29.7.0",
        "esbuild": "^0.19.4",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "jest-junit": "^16.0.0",
        "nodemon": "^3.0.1",
        "supertest": "^6.3.3",
        "typescript": "^5.2.0"
    }
}